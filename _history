ps://developers.google.com/blockly/xml\"><variables></variables><block type=\"pxt-on-start\" x=\"20\" y=\"20\"></block><block type=\"device_forever\" x=\"225\" y=\"20\"></block></xml>","main.ts":"basic.forever(function () {\n\t\n})\n","README.md":"","custom.ts":"//% weight=100 color=#0fbc11 icon=\"\\uf124\"\nnamespace gps {\n    let rxPin: SerialPin\n    let txPin: SerialPin\n    let azimuth = 0\n    let elevation = 0\n    let geoid = 0\n    let ortho = 0\n    let hdop = 0\n    let long_dir = \"\"\n    let longitude = 0\n    let lat_dir = \"\"\n    let latitude: number\n    let gps_time = \"\"\n    let gps_date = \"\"\n    let data: string[] = []\n\n    //% block=\"GPS init RX %rx TX %tx\"\n    export function init(rx: SerialPin, tx: SerialPin): void {\n        rxPin = rx\n        txPin = tx\n        serial.redirect(rxPin, txPin, BaudRate.BaudRate9600)\n        serial.setRxBufferSize(128)\n    }\n    \n    serial.onDataReceived(serial.delimiters(Delimiters.NewLine), function () {\n        data = serial.readUntil(serial.delimiters(Delimiters.NewLine)).split(\",\")\n        if (data[0].includes(\"RMC\")) {\n            gps_date = data[9]\n            gps_time = data[1]\n            latitude = convertDegree(data[3], 2)\n            lat_dir = data[4]\n            longitude = convertDegree(data[5], 3)\n            long_dir = data[6]\n        } else if (data[0].includes(\"GGA\")) {\n            hdop = parseFloat(data[8])\n            ortho = parseFloat(data[9])\n            geoid = parseFloat(data[11])\n        } else if (data[0].includes(\"GSV\")) {\n            elevation = parseFloat(data[5])\n            azimuth = parseFloat(data[6])\n        }\n    })\n\n    function convertDegree(data: string, num: number) {\n        return parseFloat(data.substr(0, num)) + parseFloat(data.substr(num, data.length - num)) / 60}\n    \n    //% block=\"time\"\n    export function time(): string {\n        return gps_time\n    }\n\n    //% block=\"date\"\n    export function date(): string {\n        return gps_date\n    }\n\n    //% block=\"latitude\"\n    export function latitude(): string {\n        return Latitude\n    }\n\n    //% block=\"GPS longitude\"\n    export function longitude(): string {\n        let sentence = readSentence()\n        if (sentence.indexOf(\"$GPRMC\") >= 0) {\n            let parts = sentence.split(\",\")\n            return parts[5] + \" \" + parts[6]\n        }\n        return \"\"\n    }\n\n    //% block=\"GPS speed (km/h)\"\n    export function speed(): number {\n        let sentence = readSentence()\n        if (sentence.indexOf(\"$GPRMC\") >= 0) {\n            let parts = sentence.split(\",\")\n            return parseFloat(parts[7]) * 1.852\n        }\n        return 0\n    }\n\n    //% block=\"GPS course\"\n    export function course(): string {\n        let sentence = readSentence()\n        if (sentence.indexOf(\"$GPRMC\") >= 0) {\n            let parts = sentence.split(\",\")\n            return parts[8]\n        }\n        return \"\"\n    }\n\n    //% block=\"GPS altitude\"\n    export function altitude(): string {\n        let sentence = readSentence()\n        if (sentence.indexOf(\"$GPGGA\") >= 0) {\n            let parts = sentence.split(\",\")\n            return parts[9] + \" m\"\n        }\n        return \"\"\n    }\n\n    //% block=\"GPS HDOP\"\n    export function hdop(): string {\n        let sentence = readSentence()\n        if (sentence.indexOf(\"$GPGGA\") >= 0) {\n            let parts = sentence.split(\",\")\n            return parts[8]\n        }\n        return \"\"\n    }\n}","pxt.json":"{\n    \"name\": \"Untitled\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"custom.ts\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1764171859545,"editorVersion":"8.0.18","text":{"main.